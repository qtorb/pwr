# PWR local environment reference
#
# Current runtime reads GEMINI_API_KEY from the process environment.
# In PowerShell, set it before starting Streamlit:
#
#   $env:GEMINI_API_KEY = "your-gemini-key"
#   .\.venv\Scripts\python.exe -m streamlit run app_main.py

GEMINI_API_KEY=your_gemini_api_key_here
