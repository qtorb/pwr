# PWR Environment Configuration
# Copy this file to .env and fill in your values for local development

# Gemini API Key - Required for LLM functionality
# Get your key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Database Path - Optional, defaults to pwr_data/pwr.db
# For local: sqlite:///pwr.db
# For production: leave empty to use default
PWR_DATABASE_URL=

# Streamlit Server Port - Optional, defaults to 8501
STREAMLIT_SERVER_PORT=8501

# Streamlit Logger Level - Optional, defaults to info
STREAMLIT_LOGGER_LEVEL=info
